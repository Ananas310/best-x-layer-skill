# Copy to .env and fill
OKX_ONCHAINOS_API_KEY=
OKX_ONCHAINOS_SECRET_KEY=
OKX_ONCHAINOS_PASSPHRASE=

# Optional endpoints
XLAYER_RPC_URL=https://xlayerrpc.okx.com
ONCHAINOS_BASE_URL=https://www.oklink.com

# Operational guards
REPUTATION_REQUEST_TIMEOUT_MS=12000
REPUTATION_OKX_MAX_RETRIES=2
REPUTATION_RPC_MAX_RETRIES=2
REPUTATION_RETRY_BASE_MS=250

# Optional: emit alerts to stderr in addition to report.meta.alerts
REPUTATION_ALERT_STDERR=false
